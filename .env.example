# Y-IT ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local for local development
# Add these variables to your production environment (Vercel, AWS, etc.)

# =====================================================================
# DATABASE
# =====================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/yit_database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=yit_database

# =====================================================================
# STRIPE (FIX #1)
# =====================================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx  # Test key for development
# STRIPE_SECRET_KEY=sk_live_xxxxx  # Live key for production

# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Optional: Publishable key for frontend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# =====================================================================
# REDIS (FIX #2)
# =====================================================================
# Local development
REDIS_URL=redis://localhost:6379

# Production (AWS ElastiCache)
# REDIS_URL=redis://yit-rate-limiter.xxxxx.cache.amazonaws.com:6379

# Optional: Redis password if authentication enabled
# REDIS_PASSWORD=your_redis_password

# =====================================================================
# OPENAI API (Evaluator)
# =====================================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Optional: Organization ID
# OPENAI_ORG_ID=org-xxxxx

# =====================================================================
# AWS (FIX #4 - Backups)
# =====================================================================
# For S3 backups and RDS access
AWS_ACCESS_KEY_ID=AKIAXXXXX
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-east-1

# S3 bucket for backups
S3_BACKUP_BUCKET=yit-backups

# =====================================================================
# CONVERTKIT (Email)
# =====================================================================
# Get from: https://app.convertkit.com/account/edit
CONVERTKIT_API_KEY=xxxxx
CONVERTKIT_API_SECRET=xxxxx

# ConvertKit forms and sequences
CK_FORM_ID_EVALUATOR=xxxxx
CK_SEQUENCE_ID_POST_EVALUATOR=xxxxx

# =====================================================================
# MONITORING & ALERTS
# =====================================================================
# Slack webhook for alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# Sentry for error tracking (optional)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =====================================================================
# FEATURE FLAGS (FIX #5)
# =====================================================================
# Enable/disable features
FEATURE_FLAG_OPTIMIZED_FORM=true
DISABLE_RATE_LIMITING=false

# A/B test split (0.0 to 1.0)
AB_TEST_OPTIMIZED_FORM_PERCENTAGE=0.5

# =====================================================================
# APPLICATION
# =====================================================================
# Base URL (for redirects, webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://yit.app  # Production

# Environment
NODE_ENV=development
# NODE_ENV=production

# =====================================================================
# OPTIONAL: EXTERNAL SERVICES
# =====================================================================
# Gumroad (for digital downloads)
GUMROAD_API_KEY=xxxxx

# KDP/Amazon (for print books)
AMAZON_ASSOCIATE_ID=xxxxx

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS=true
