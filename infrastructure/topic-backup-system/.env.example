# Google Drive API Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials

# OAuth 2.0 Client ID (recommended for user data)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# OR Service Account (recommended for automated backups)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# Google Drive Settings
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# Local Configuration
PRODUCTION_ROOT=/home/user/Y-it-nano/production
DATABASE_PATH=./sync-state.db
TEMP_PATH=./temp

# Sync Settings
WATCH_MODE=true
WATCH_DEBOUNCE_MS=5000
BATCH_SIZE=10
PARALLEL_UPLOADS=3
CHECK_INTERVAL_MS=60000

# Compression
COMPRESSION_ENABLED=true
RESUMABLE_UPLOAD_THRESHOLD_BYTES=5242880

# Notifications (Optional)
SLACK_WEBHOOK_URL=
NOTIFY_ON_PHASE_COMPLETE=true
NOTIFY_ON_BATCH_COMPLETE=true
NOTIFY_ON_ERROR=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/sync.log

# Advanced Settings
MAX_RETRIES=3
RETRY_BACKOFF_MULTIPLIER=2
KEEP_VERSIONS=3
DRY_RUN=false
