{
  "googleDrive": {
    "rootFolderName": "Y-IT-Production",
    "compressionEnabled": true,
    "resumableUploadThreshold": 5242880,
    "maxRetries": 3,
    "retryBackoffMultiplier": 2,
    "keepVersions": 3
  },
  "local": {
    "productionRoot": "/home/user/Y-it-nano/production",
    "databasePath": "./sync-state.db",
    "tempPath": "./temp"
  },
  "sync": {
    "watchMode": true,
    "watchDebounceMs": 5000,
    "batchSize": 10,
    "parallelUploads": 3,
    "checkInterval": 60000
  },
  "notifications": {
    "enabled": false,
    "slackWebhookUrl": "",
    "notifyOnPhaseComplete": true,
    "notifyOnBatchComplete": true,
    "notifyOnError": true
  },
  "exclude": [
    ".DS_Store",
    ".git",
    "node_modules",
    "*.tmp",
    "*.temp",
    "*.log",
    ".cache",
    "thumbs.db"
  ],
  "phases": [
    {
      "id": 0,
      "name": "Phase-0-Research",
      "requiredFiles": [
        "*_research_engine.md"
      ],
      "optionalFiles": [
        "market_analysis.pdf",
        "competitor_research.md"
      ]
    },
    {
      "id": 1,
      "name": "Phase-1-Strategy",
      "requiredFiles": [
        "*_research_summary.md",
        "*_content_strategy.md"
      ],
      "optionalFiles": []
    },
    {
      "id": 2,
      "name": "Phase-2-Case-Studies",
      "requiredFiles": [
        "*_case_studies.md"
      ],
      "optionalFiles": []
    },
    {
      "id": 3,
      "name": "Phase-3-Content",
      "requiredFiles": [
        "*_manuscript_full.md",
        "*_manuscript_compressed.md"
      ],
      "optionalFiles": [
        "*_content_extraction.md",
        "*_24page_structure.*"
      ]
    },
    {
      "id": 4,
      "name": "Phase-4-Design-Specs",
      "requiredFiles": [
        "*_image_specifications.md"
      ],
      "optionalFiles": [
        "*_hero_brief.md",
        "*_comic_strip_brief.md"
      ]
    },
    {
      "id": 5,
      "name": "Phase-5-Audit",
      "requiredFiles": [
        "*_manuscript_audit.md"
      ],
      "optionalFiles": []
    },
    {
      "id": 6,
      "name": "Phase-6-Designer-Handoff",
      "requiredFiles": [
        "*_designer_brief.md",
        "*_complete_spec_package.md"
      ],
      "optionalFiles": []
    },
    {
      "id": 7,
      "name": "Phase-7-Design-Production",
      "requiredFiles": [],
      "optionalFiles": [
        "*.indd",
        "*_proof_v*.pdf"
      ]
    },
    {
      "id": 8,
      "name": "Phase-8-Final-Assets",
      "requiredFiles": [
        "*_KDP_final.pdf"
      ],
      "optionalFiles": [
        "*_gumroad.pdf",
        "*_web_version/*"
      ]
    },
    {
      "id": 9,
      "name": "Phase-9-Quality",
      "requiredFiles": [
        "quality_checklist.md"
      ],
      "optionalFiles": [
        "approval_sign_off.md"
      ]
    }
  ],
