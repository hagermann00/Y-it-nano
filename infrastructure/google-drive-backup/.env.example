# ============================================================================
# Y-IT Google Drive Backup Configuration
# ============================================================================

# Google Drive API Configuration
# --------------------------------
# Path to service account key JSON file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account-key.json

# Google Drive folder ID (optional - will be created if not specified)
# To get folder ID: Open folder in Drive, copy ID from URL
# Example: https://drive.google.com/drive/folders/1abc123def456 -> ID is "1abc123def456"
GDRIVE_BACKUP_FOLDER_ID=

# Backup folder name (used if GDRIVE_BACKUP_FOLDER_ID is not set)
GDRIVE_FOLDER_NAME=Y-IT-Backups

# Database Configuration
# ----------------------
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=yit_database
DB_USER=postgres
DB_PASSWORD=your_secure_database_password

# Backup Settings
# ---------------
# Directory for temporary backup files (will be created if doesn't exist)
BACKUP_TEMP_DIR=/tmp/yit-backups

# Number of days to retain backups (default: 30)
BACKUP_RETENTION_DAYS=30

# Compression level for pg_dump (0-9, default: 9 = maximum compression)
COMPRESSION_LEVEL=9

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY_MS=5000

# Notification Settings
# ---------------------
# Enable/disable notifications
NOTIFICATIONS_ENABLED=true

# Slack webhook URL (optional)
# Create webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email notification (optional - requires additional email service setup)
NOTIFICATION_EMAIL=admin@yourdomain.com

# Critical Files to Backup
# -------------------------
# These files are backed up in addition to the database
# Add additional files as comma-separated paths (relative to project root)
# CRITICAL_FILES=.env.production,package.json,infrastructure/disaster_recovery.md
